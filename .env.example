# Gateway settings (GATEWAY_ prefix) — see the mcp-gtw configuration guide.

# where the server listens
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8000
GATEWAY_MCP_STATELESS=true

# origins allowed to reach the public mcp endpoint, empty accepts native clients only
GATEWAY_ALLOWED_MCP_ORIGINS=

# origins allowed by cors on the http endpoints
GATEWAY_CORS_ALLOW_ORIGINS=*

# execution and safety limits
GATEWAY_TOOL_CALL_TIMEOUT_SECONDS=60
GATEWAY_OFFLINE_TTL_SECONDS=300

# admin dashboard, disabled by default, set a key to require ?key=<value>
GATEWAY_ADMIN_ENABLED=false
GATEWAY_ADMIN_KEY=

# Game settings (APP_ prefix) — see src/app/config.py.
APP_TICK_RATE=15
APP_BASE_MAX_HEALTH=100
APP_BASE_MOVE_DURATION=0.28
APP_BASE_VISION_RANGE=6
APP_BASE_ATTACK_SPEED=1.0
APP_SPAWN_IMMUNITY_SECONDS=5
APP_ENTRY_ANIMATION_SECONDS=0.6
APP_RESPAWN_DELAY_SECONDS=3
APP_SESSION_GRACE_SECONDS=30
APP_STREAM_SEND_TIMEOUT_SECONDS=2
APP_FOOD_HEAL=40
APP_FOOD_SPAWN_INTERVAL=120
APP_PICKUP_CAP=6
APP_PICKUP_SPAWN_INTERVAL=120
APP_COIN_CAP=8
APP_COIN_SPAWN_INTERVAL=120
APP_TREE_REGROW_SECONDS=120
APP_WOOD_PER_TREE=3
APP_NAME_MAX_LENGTH=32
APP_SPEECH_MAX_LENGTH=50
